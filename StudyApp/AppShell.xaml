<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="StudyApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
    BackgroundColor="{StaticResource PageBackground}"
    NavigationPage.HasNavigationBar="False"
    ios:Page.UseSafeArea="True"
    Title="StudyApp">

    <Grid>
        <Grid
            x:Name="ContentHost"
            Padding="0,0,0,112" />

        <Border
            Margin="16,0,16,16"
            BackgroundColor="{StaticResource Surface}"
            Padding="8,8"
            Stroke="{StaticResource Divider}"
            StrokeShape="RoundRectangle 28"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="#164D6D8F"
                    Offset="0,8"
                    Radius="20" />
            </Border.Shadow>

            <!-- Tab bar layout (3 equal tabs) -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border
                    x:Name="HomeTabButton"
                    BackgroundColor="Transparent"
                    MinimumHeightRequest="56"
                    Padding="8,6"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTabTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                        <Grid
                            HeightRequest="24"
                            HorizontalOptions="Center"
                            WidthRequest="24">
                            <Path
                                x:Name="HomeTabIcon"
                                Aspect="Uniform"
                                Data="M4.75 10.2L12 4.5L19.25 10.2V18.25C19.25 18.8023 18.8023 19.25 18.25 19.25H14.75V14C14.75 13.4477 14.3023 13 13.75 13H10.25C9.69772 13 9.25 13.4477 9.25 14V19.25H5.75C5.19772 19.25 4.75 18.8023 4.75 18.25V10.2Z"
                                Fill="Transparent"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeLineJoin="Round"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                        </Grid>
                        <Label
                            x:Name="HomeTabLabel"
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            LineHeight="1"
                            Text="Home"
                            TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    x:Name="NotesTabButton"
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    MinimumHeightRequest="56"
                    Padding="8,6"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotesTabTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                        <Grid
                            HeightRequest="24"
                            HorizontalOptions="Center"
                            WidthRequest="24">
                            <Path
                                x:Name="NotesTabFrame"
                                Aspect="Uniform"
                                Data="M7.5 4.75H16.5C17.8807 4.75 19 5.86929 19 7.25V16.75C19 18.1307 17.8807 19.25 16.5 19.25H7.5C6.11929 19.25 5 18.1307 5 16.75V7.25C5 5.86929 6.11929 4.75 7.5 4.75Z"
                                Fill="Transparent"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                            <Path
                                x:Name="NotesTabLine1"
                                Aspect="Uniform"
                                Data="M8.5 9.25H15.5"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeLineCap="Round"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                            <Path
                                x:Name="NotesTabLine2"
                                Aspect="Uniform"
                                Data="M8.5 12.5H15.5"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeLineCap="Round"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                            <Path
                                x:Name="NotesTabLine3"
                                Aspect="Uniform"
                                Data="M8.5 15.75H12.5"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeLineCap="Round"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                        </Grid>
                        <Label
                            x:Name="NotesTabLabel"
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            LineHeight="1"
                            Text="Notes"
                            TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    x:Name="ProfileTabButton"
                    Grid.Column="2"
                    BackgroundColor="Transparent"
                    MinimumHeightRequest="56"
                    Padding="8,6"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTabTapped" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                        <Grid
                            HeightRequest="24"
                            HorizontalOptions="Center"
                            WidthRequest="24">
                            <Ellipse
                                x:Name="ProfileTabHead"
                                Fill="Transparent"
                                HeightRequest="8"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeThickness="1.8"
                                TranslationY="-4"
                                VerticalOptions="Center"
                                WidthRequest="8" />
                            <Path
                                x:Name="ProfileTabBody"
                                Aspect="Uniform"
                                Data="M5 18.25C5.96656 15.7386 8.64853 14 12 14C15.3515 14 18.0334 15.7386 19 18.25"
                                HeightRequest="24"
                                HorizontalOptions="Center"
                                Stroke="{StaticResource Gray500}"
                                StrokeLineCap="Round"
                                StrokeThickness="1.8"
                                VerticalOptions="Center"
                                WidthRequest="24" />
                        </Grid>
                        <Label
                            x:Name="ProfileTabLabel"
                            FontAttributes="Bold"
                            FontSize="12"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            LineHeight="1"
                            Text="Profile"
                            TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ContentPage>

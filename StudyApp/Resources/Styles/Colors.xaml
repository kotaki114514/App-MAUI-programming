<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#7CB8F6</Color>
    <Color x:Key="PrimaryDark">#5E98D7</Color>
    <Color x:Key="PrimaryDarkText">#14314B</Color>
    <Color x:Key="Secondary">#EAF4FF</Color>
    <Color x:Key="SecondaryDarkText">#345C84</Color>
    <Color x:Key="Tertiary">#2E6EAD</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">#08131F</Color>
    <Color x:Key="Magenta">#7CB8F6</Color>
    <Color x:Key="MidnightBlue">#15324C</Color>
    <Color x:Key="OffBlack">#0E1824</Color>

    <Color x:Key="Gray100">#F7FAFD</Color>
    <Color x:Key="Gray200">#E3ECF6</Color>
    <Color x:Key="Gray300">#CAD8E6</Color>
    <Color x:Key="Gray400">#A6B8C9</Color>
    <Color x:Key="Gray500">#708398</Color>
    <Color x:Key="Gray600">#46586C</Color>
    <Color x:Key="Gray900">#17283A</Color>
    <Color x:Key="Gray950">#0E1A28</Color>

    <Color x:Key="PageBackground">#F3F8FF</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceAlt">#EEF5FF</Color>
    <Color x:Key="InputBackground">#F5F9FF</Color>
    <Color x:Key="Divider">#D8E5F3</Color>
    <Color x:Key="PrimarySurface">#E6F1FF</Color>
    <Color x:Key="AccentSurface">#EEF2FF</Color>
    <Color x:Key="Success">#2E9A68</Color>
    <Color x:Key="SuccessSurface">#E9F8F0</Color>
    <Color x:Key="SuccessText">#216E4A</Color>
    <Color x:Key="Danger">#D9506E</Color>
    <Color x:Key="DangerSurface">#FFECEF</Color>
    <Color x:Key="DangerText">#B53454</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAlt}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="PrimarySurfaceBrush" Color="{StaticResource PrimarySurface}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="{StaticResource SuccessSurface}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurface}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
